from pybricks.hubs import PrimeHub
from pybricks.parameters import Direction, Port
from pybricks.pupdevices import Motor
from pybricks.robotics import DriveBase

# Set up all devices.
prime_hub = PrimeHub()
Left_Motor = Motor(Port.A, Direction.COUNTERCLOCKWISE)
Right_Motor = Motor(Port.B, Direction.CLOCKWISE)
Attachment_Motor_1__Left_ = Motor(Port.C, Direction.CLOCKWISE)
Attachment_Motor_2__Right_ = Motor(Port.D, Direction.COUNTERCLOCKWISE)
Berry_Jr_ = DriveBase(Left_Motor, Right_Motor, 62.5, 134.7)

def deliver():
    Berry_Jr_.use_gyro(True)
    Berry_Jr_.settings(straight_speed=900)
    Berry_Jr_.settings(turn_rate=720)
    Berry_Jr_.straight(250)
    Berry_Jr_.turn(-90)
    Berry_Jr_.straight(1250)
    Berry_Jr_.turn(90)
    Berry_Jr_.straight(150)
    Berry_Jr_.turn(60)
    Berry_Jr_.straight(120)
    Berry_Jr_.straight(-500)


# The main program starts here.
deliver()
