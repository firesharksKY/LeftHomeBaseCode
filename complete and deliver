from pybricks.hubs import PrimeHub
from pybricks.parameters import Button, Direction, Port, Stop
from pybricks.pupdevices import Motor
from pybricks.robotics import DriveBase
from pybricks.tools import multitask, run_task, wait

# Set up all devices.
prime_hub = PrimeHub()
Left_Motor = Motor(Port.A, Direction.COUNTERCLOCKWISE)
Right_Motor = Motor(Port.B, Direction.CLOCKWISE)
Attachment_Motor_1__Left_ = Motor(Port.C, Direction.CLOCKWISE)
Attachment_Motor_1__Right_ = Motor(Port.D, Direction.COUNTERCLOCKWISE)
Berry_Jr_ = DriveBase(Left_Motor, Right_Motor, 62.5, 134.7)

# Initialize variables.
var = 0

async def complete_and_deliver():
    global var
    await wait(0)
    var = 0
    prime_hub.system.set_stop_button(Button.BLUETOOTH)
    # innitial setup
    Berry_Jr_.use_gyro(True)
    Berry_Jr_.settings(straight_speed=900)
    Berry_Jr_.settings(turn_rate=180)
    # complete 5, 6, and 8, then come back home
    await complete()

async def complete():
    await wait(0)
    await Berry_Jr_.straight(750)
    await Berry_Jr_.turn(41)
    await Berry_Jr_.straight(-50)
    await Attachment_Motor_1__Right_.run_angle(2400, -500)
    await wait(100)
    Berry_Jr_.settings(straight_speed=100)
    await Berry_Jr_.straight(90)
    Attachment_Motor_1__Right_.control.limits(acceleration=720)
    await Attachment_Motor_1__Right_.run_angle(2800, 500)
    await Berry_Jr_.straight(-50)
    await Berry_Jr_.turn(-42)
    await Berry_Jr_.straight(60)
    Berry_Jr_.settings(turn_rate=360)
    await Berry_Jr_.turn(-60)
    await Berry_Jr_.turn(60)
    await Berry_Jr_.straight(-100)
    Berry_Jr_.settings(turn_rate=720)
    await Berry_Jr_.turn(92)
    Berry_Jr_.settings(straight_speed=750)
    await Berry_Jr_.straight(350)
    await Berry_Jr_.straight(-370)
    await Berry_Jr_.turn(-92)
    await Berry_Jr_.straight(-400)
    await Berry_Jr_.turn(92)
    await Berry_Jr_.straight(170)
    await Berry_Jr_.turn(-92)
    await Berry_Jr_.straight(60)
    Attachment_Motor_1__Left_.control.limits(acceleration=20000)
    for count in range(3):
        await wait(0)
        await Attachment_Motor_1__Left_.run_angle(10000, -500, Stop.COAST)
        await Attachment_Motor_1__Left_.run_angle(10000, 500, Stop.COAST)
    Berry_Jr_.settings(straight_speed=1000)
    await Berry_Jr_.straight(-400)

async def deliver(wait_time, turn_off_):
    global var
    await wait(0)
    Berry_Jr_.settings(straight_speed=900)
    Berry_Jr_.settings(turn_rate=720)
    await wait(wait_time)
    await Berry_Jr_.straight(250)
    await Berry_Jr_.turn(-90)
    await Berry_Jr_.straight(1250)
    await Berry_Jr_.turn(90)
    await Berry_Jr_.straight(150)
    await Berry_Jr_.turn(60)
    await Berry_Jr_.straight(120)
    var = turn_off_
    await Berry_Jr_.straight(-500)

async def main1():
    await complete_and_deliver()

async def main2():
    while not var == 1:
        await wait(0)
    await wait(700)
    prime_hub.system.shutdown()


async def main():
    await multitask(main1(), main2())

run_task(main())
